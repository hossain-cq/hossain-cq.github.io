---
layout: null
permalink: /feed.xml
---
<?xml version="1.0" encoding="utf-8"?>
<?xml-stylesheet type="text/xsl" href="{{ '/feed.xsl' | relative_url }}"?>
<feed xmlns="http://www.w3.org/2005/Atom">
  <title>Hossain Quantum Research — News</title>
  <subtitle>Research milestones, publications, and updates from Dr. Hossain</subtitle>
  <link href="{{ '/feed.xml' | absolute_url }}" rel="self" />
  <link href="{{ '/' | absolute_url }}" />
  <updated>{{ site.time | date_to_xmlschema }}</updated>
  <id>{{ '/' | absolute_url }}</id>
  <author>
    <name>Sk Mujaffar Hossain</name>
  </author>
  {% assign sorted_news = site.data.news | sort: 'date' | reverse %}
  {% for item in sorted_news %}
  {% if item.link_url %}{% assign entry_link = item.link_url %}{% else %}{% assign entry_link = '/news/' | absolute_url %}{% endif %}
  <entry>
    <title>{{ item.headline | strip_html }}</title>
    <link href="{{ entry_link }}" />
    <id>{{ site.url }}/news/#{{ item.date }}-{{ forloop.index }}</id>
    <published>{{ item.date | date_to_xmlschema }}</published>
    <updated>{{ item.date | date_to_xmlschema }}</updated>
    <category term="{{ item.type }}" />
    <summary type="text">{{ item.body | strip_html | xml_escape }}</summary>
  </entry>
  {% endfor %}
</feed>
